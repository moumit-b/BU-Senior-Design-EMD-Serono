# Environment Variables Template
# Copy this file to .env and fill in your values

# === Unified LLM Configuration (Anthropic) ===
# This system is now standardized on Anthropic Claude models for all research profiles.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# === Optional Configuration ===

# BioMCP SSL Certificate fix (Set to true if on Merck corporate network)
BIOMCP_DISABLE_SSL=false
# SSL_CERT_PATH=C:/path/to/merck/ca_bundle.pem

# Local Fallback (Ollama) - Set LLM_PROVIDER=ollama in config.py or environment
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
