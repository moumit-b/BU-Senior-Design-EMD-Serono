# Environment Variables Template
# Copy this file to .env and fill in your values
#
# Three configuration profiles are available:
#   1. Standard  - Anthropic Claude (requires API key)
#   2. Merck     - Azure OpenAI / AWS Bedrock (requires enterprise key)
#   3. Ollama    - Local LLM via Ollama (no API key needed)

# === LLM Provider ===
# Set to "anthropic" (default) or "ollama" for local mode
LLM_PROVIDER=anthropic

# === Anthropic Configuration (Standard Profile) ===
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# === Ollama Configuration (Local Profile) ===
# Uncomment these lines and set LLM_PROVIDER=ollama for local mode
# Requires: ollama serve running + model pulled
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:235b-thinking
# OLLAMA_TIMEOUT=600

# === Merck Enterprise Configuration ===
# Uncomment for Merck Azure OpenAI / Bedrock access
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_API_KEY=your-azure-key

# === Optional ===
# BioMCP SSL Certificate fix (Merck corporate network)
BIOMCP_DISABLE_SSL=false
# SSL_CERT_PATH=C:/path/to/merck/ca_bundle.pem
